{
  "name": "voice-first-sfu-project",
  "private": true,
  "scripts": {
    "build": "npm --prefix app run build",
    "dev": "npm --prefix app run dev -w webapp",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "format": "prettier --write . && gofmt -w backend",
    "format:check": "prettier --check .",
    "lint": "npm --prefix app run lint -w webapp && cd backend && go test ./...",
    "test:backend": "cd backend && go test ./...",
    "test": "npm run lint"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "vitepress": "^1.6.4"
  }
}
